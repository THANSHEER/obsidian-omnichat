{
	"name": "aibrowser-chat",
	"version": "1.2.0",
	"description": "Obsidian plugin — embeds AI chat services in a sidebar and injects vault notes as context.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.19.19",
		"esbuild": "^0.28.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "14.0.0",
		"jiti": "^2.7.0",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.3",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"obsidian": "^1.12.3"
	}
}
